# Telegram bot token from @BotFather
BOT_TOKEN=

# LTA DataMall AccountKey, request one at
# https://datamall.lta.gov.sg/content/datamall/en/request-for-api.html
LTA_ACCOUNT_KEY=

# Path to the SQLite database file (created automatically if missing)
DB_PATH=./data/bot.db

# Button shown on /start that opens the companion web app
WEBAPP_URL=https://sgbus.uwuapps.org/

# Button shown on /start that links to the donation page
DONATE_URL=https://donate.stripe.com/28o2akeAr3hv0DK6oo

# How often (in hours) to refresh the cached bus stop list from LTA DataMall
BUS_STOPS_REFRESH_HOURS=24
